ITS_HOST=0.0.0.0
ITS_PORT=8000
ITS_DEBUG=false
# google/gemma-4-E2B-it is Apache 2.0 — no token required.
# Switch to a larger model (e.g. google/gemma-4-E4B-it) if hardware allows.
ITS_MODEL_NAME=google/gemma-4-E2B-it
ITS_DEVICE=auto
ITS_MAX_IMAGE_DIMENSION=1024
ITS_AUTH_ENABLED=false
ITS_API_KEY=
ITS_LOG_LEVEL=INFO
ITS_LOG_FORMAT=console

# Optional: HuggingFace token for private/gated models.
# Not needed for google/gemma-4-E2B-it (Apache 2.0, public).
# Also reads HF_TOKEN / HUGGING_FACE_HUB_TOKEN from the environment.
ITS_HF_TOKEN=

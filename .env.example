ITS_HOST=0.0.0.0
ITS_PORT=8000
ITS_DEBUG=false
ITS_MODEL_NAME=google/gemma-4-4b-it
ITS_DEVICE=auto
ITS_MAX_IMAGE_DIMENSION=1024
ITS_AUTH_ENABLED=false
ITS_API_KEY=
ITS_LOG_LEVEL=INFO
ITS_LOG_FORMAT=console

# HuggingFace token — REQUIRED for gated models such as Gemma 4.
# 1. Accept the model license at https://huggingface.co/google/gemma-4-4b-it
# 2. Create a token at https://huggingface.co/settings/tokens (read access is enough)
# 3. Paste it below (or export HF_TOKEN in your shell — the service reads both)
ITS_HF_TOKEN=
